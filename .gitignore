# ============================================================
#  SIMAK — .gitignore
# ============================================================

# Kredensial & Keamanan (JANGAN commit!)
credentials/service-account.json
config/database.php

# Upload temp
uploads/*
!uploads/.gitkeep
!uploads/.htaccess

# Vendor (Composer)
vendor/

# Environment
.env
*.env

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# PHP Logs
*.log
error_log
php_errorlog

# Backup files
*.bak
*.backup
*.sql.gz
